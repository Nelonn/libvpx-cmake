#ifndef VPX_CONFIG_H
#define VPX_CONFIG_H

/**
 * Auto-generated configuration header for libvpx
 * This file is generated by CMake from vpx_config.h.in
 */

/* Codec features */
#cmakedefine01 CONFIG_VP8
#cmakedefine01 CONFIG_VP9
#cmakedefine01 CONFIG_ENCODERS
#cmakedefine01 CONFIG_DECODERS
#cmakedefine01 CONFIG_MULTITHREAD
#cmakedefine01 CONFIG_VP9_HIGHBITDEPTH
#cmakedefine01 CONFIG_POSTPROC
#cmakedefine01 CONFIG_VP9_POSTPROC
#cmakedefine01 CONFIG_SPATIAL_RESAMPLING
#cmakedefine01 CONFIG_TEMPORAL_DENOISING
#cmakedefine01 CONFIG_VP9_TEMPORAL_DENOISING
#cmakedefine01 CONFIG_ERROR_CONCEALMENT
#cmakedefine01 CONFIG_RUNTIME_CPU_DETECT
#cmakedefine01 CONFIG_REALTIME_ONLY
#cmakedefine01 CONFIG_ONTHEFLY_BITPACKING
#cmakedefine01 CONFIG_OS_SUPPORT
#cmakedefine01 CONFIG_INTERNAL_STATS
#cmakedefine01 CONFIG_VP8_ENCODER
#cmakedefine01 CONFIG_VP8_DECODER
#cmakedefine01 CONFIG_VP9_ENCODER
#cmakedefine01 CONFIG_VP9_DECODER

/* X86 SIMD features */
#cmakedefine01 HAVE_MMX
#cmakedefine01 HAVE_SSE2
#cmakedefine01 HAVE_SSE3
#cmakedefine01 HAVE_SSSE3
#cmakedefine01 HAVE_SSE4_1
#cmakedefine01 HAVE_AVX
#cmakedefine01 HAVE_AVX2
#cmakedefine01 HAVE_AVX512
#cmakedefine01 HAVE_X86_ASM

/* ARM NEON features */
#cmakedefine01 HAVE_NEON
#cmakedefine01 HAVE_NEON_DOTPROD
#cmakedefine01 HAVE_NEON_I8MM
#cmakedefine01 HAVE_NEON_ASM
#cmakedefine01 HAVE_SVE
#cmakedefine01 HAVE_SVE2

/* Architecture detection */
#cmakedefine01 VPX_ARCH_X86
#cmakedefine01 VPX_ARCH_X86_64
#cmakedefine01 VPX_ARCH_ARM
#cmakedefine01 VPX_ARCH_AARCH64

/* Inline keyword */
#ifndef INLINE
#if defined(_MSC_VER)
#define INLINE __inline
#else
#define INLINE inline
#endif
#endif

/* Threading support */
#cmakedefine HAVE_PTHREAD_H @HAVE_PTHREAD_H@

#endif /* VPX_CONFIG_H */
